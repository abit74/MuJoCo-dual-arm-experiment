<mujoco>
  <compiler angle="radian" meshdir="./mesh" texturedir="./texture"/>

  <visual>
    <quality shadowsize="8192" offsamples="8" numslices="64" numstacks="64"/>
    <headlight active="1"/>
    <rgba haze="0.15 0.25 0.35 1"/>
  </visual>

  <option timestep="0.001" integrator="Euler" iterations="50" solver="Newton"
          impratio="5" noslip_iterations="5" tolerance="1e-8" cone="elliptic">
    <flag actuation="enable" gravity="enable" warmstart="enable"/>
  </option>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0" width="512" height="512"/>
    <texture name="plane" type="2d" builtin="checker" rgb1=".2 .3 .4" rgb2=".1 0.15 0.2"
             width="512" height="512" mark="cross" markrgb=".8 .8 .8"/>
    <material name="plane" reflectance="0.3" texture="plane" texrepeat="1 1" texuniform="true"/>

    <material name="mat_red" rgba="1 0 0 1"/>
    <material name="mat_green" rgba="0 1 0 1"/>
    <material name="mat_blue" rgba="0 0.35 1 1"/>
    <material name="mat_yellow" rgba="1 1 0 1"/>
    <material name="mat_white" rgba="0.85 0.85 0.85 1"/>
  </asset>

  <!-- Robot 1 is positioned inside panda.xml at x=-0.45 -->
  <include file="panda.xml"/>

  <!-- Robot 2 is positioned inside panda2.xml at x=+0.55 -->
  <include file="panda2.xml"/>

  <worldbody>
    <!-- User-requested fixed camera view -->
    <camera name="cam" pos="0.5 -1.75 1.00" xyaxes="1 0 0 0 0.48 0.88" fovy="70"/>

    <light directional="true" diffuse=".2 .2 .2" specular="0 0 0" pos="0 1 5" dir="0 -1 -1" castshadow="false"/>
    <light directional="false" diffuse=".8 .8 .8" specular="0.3 0.3 0.3" pos="0 -1 4" dir="0 0 -1"/>
    <light directional="true" diffuse="0 0 0" specular=".7 .7 .7" pos="0 3 3" dir="0 -3 -3"/>

    <geom name="floor" pos="0 0 0" group="1" size="0 0 .1" type="plane" material="plane" condim="3"/>

    <!-- Robot 1 target sites / workspace markers -->
    <site name="robot1_place" pos="-0.58 0.18 0.03" size="0.025" rgba="1 1 1 0.5"/>
    <site name="robot1_home_zone" pos="-0.45 -0.35 0.03" size="0.02" rgba="1 1 1 0.3"/>

    <!-- Robot 2 target sites / workspace markers -->
    <site name="robot2_place" pos="0.58 0.18 0.03" size="0.025" rgba="1 1 1 0.5"/>
    <site name="robot2_home_zone" pos="0.55 -0.35 0.03" size="0.02" rgba="1 1 1 0.3"/>

    <!-- Common aliases kept for older parser compatibility -->
    <site name="bin_center" pos="-0.58 0.18 0.03" size="0.015" rgba="1 1 1 0.3"/>
    <site name="zone_left" pos="-0.58 0.18 0.03" size="0.015" rgba="1 1 1 0.3"/>
    <site name="zone_right" pos="0.58 0.18 0.03" size="0.015" rgba="1 1 1 0.3"/>

    <!-- Robot 1 objects: red, yellow, white -->
    <body name="red_box" pos="-0.65 -0.35 0.03">
      <joint name="red_box_free" type="free"/>
      <inertial pos="0 0 0" mass="0.05" diaginertia="1e-4 1e-4 1e-4"/>
      <geom name="red_box_geom" type="box" size="0.03 0.03 0.03" condim="6" friction="1.2 0.01 0.001" material="mat_red"/>
    </body>

    <body name="yellow_box" pos="-0.45 -0.35 0.03">
      <joint name="yellow_box_free" type="free"/>
      <inertial pos="0 0 0" mass="0.05" diaginertia="1e-4 1e-4 1e-4"/>
      <geom name="yellow_box_geom" type="box" size="0.03 0.03 0.03" condim="6" friction="1.2 0.01 0.001" material="mat_yellow"/>
    </body>

    <body name="box" pos="-0.25 -0.35 0.03">
      <joint name="box_free" type="free"/>
      <inertial pos="0 0 0" mass="0.05" diaginertia="1e-4 1e-4 1e-4"/>
      <geom name="box_geom" type="box" size="0.03 0.03 0.03" condim="6" friction="1.2 0.01 0.001" material="mat_white"/>
    </body>

    <!-- Robot 2 objects: green, blue -->
    <body name="green_box" pos="0.45 -0.35 0.03">
      <joint name="green_box_free" type="free"/>
      <inertial pos="0 0 0" mass="0.05" diaginertia="1e-4 1e-4 1e-4"/>
      <geom name="green_box_geom" type="box" size="0.03 0.03 0.03" condim="6" friction="1.2 0.01 0.001" material="mat_green"/>
    </body>

    <body name="blue_box" pos="0.65 -0.35 0.03">
      <joint name="blue_box_free" type="free"/>
      <inertial pos="0 0 0" mass="0.05" diaginertia="1e-4 1e-4 1e-4"/>
      <geom name="blue_box_geom" type="box" size="0.03 0.03 0.03" condim="6" friction="1.2 0.01 0.001" material="mat_blue"/>
    </body>
  </worldbody>

  <equality/>
</mujoco>
